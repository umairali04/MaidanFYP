generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// ENUMS
// ============================================

enum Role {
  PLAYER
  GROUND_OWNER
}

enum SportType {
  CRICKET
  FOOTBALL
  HOCKEY
  BADMINTON
  TENNIS
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

// ============================================
// USER
// ============================================

model User {
  id          String   @id @default(uuid())
  name        String
  email       String   @unique
  password    String
  phone       String?
  image       String?
  role        Role     @default(PLAYER)
  isVerified  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Player relations
  bookings            Booking[]
  reviews             Review[]
  notifications       Notification[]

  // Ground Owner relations
  ownedGrounds        Ground[]
  revenueReports      RevenueReport[]

  emailVerifications  EmailVerification[]
}

// ============================================
// GROUND
// ============================================

model Ground {
  id            String    @id @default(uuid())
  name          String
  description   String?
  sportType     SportType
  location      String
  city          String
  latitude      Float?
  longitude     Float?
  pricePerHour  Float
  images        String[]
  facilities    String[]
  openTime      String    // "06:00"
  closeTime     String    // "23:00"
  slotDuration  Int       @default(60) // minutes
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  ownerId       String
  owner         User      @relation(fields: [ownerId], references: [id])

  bookings      Booking[]
  reviews       Review[]
  blockedSlots  BlockedSlot[]
  revenueReports RevenueReport[]
}

// ============================================
// BLOCKED SLOT (owner blocks specific hours)
// ============================================

// ============================================
// BLOCKED SLOT (replaces both BlockedSlot + BlockedDay)
// ============================================

model BlockedSlot {
  id        String   @id @default(uuid())
  groundId  String
  date      DateTime
  startTime String   // "06:00" ← use ground's openTime for full day block
  endTime   String   // "23:00" ← use ground's closeTime for full day block
  reason    String?
  isFullDay Boolean  @default(false)  // just a helper flag for UI display
  createdAt DateTime @default(now())

  ground    Ground   @relation(fields: [groundId], references: [id])
}

// ============================================
// BOOKING
// ============================================

model Booking {
  id            String        @id @default(uuid())
  userId        String
  groundId      String
  bookingDate   DateTime
  startTime     String        // "10:00"
  endTime       String        // "12:00"
  duration      Int           // hours
  totalPrice    Float
  status        BookingStatus @default(PENDING)
  notes         String?
  
  // Owner self-booking flag
  isOwnerBooking Boolean      @default(false)
  
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  user          User          @relation(fields: [userId], references: [id])
  ground        Ground        @relation(fields: [groundId], references: [id])
  payment       Payment?
}

// ============================================
// PAYMENT
// ============================================

model Payment {
  id            String        @id @default(uuid())
  bookingId     String        @unique
  amount        Float
  paymentStatus PaymentStatus @default(PENDING)
  transactionId String?
  method        String?       // "JazzCash", "EasyPaisa", "Card", "Cash"
  paidAt        DateTime?
  createdAt     DateTime      @default(now())

  booking       Booking       @relation(fields: [bookingId], references: [id])
}

// ============================================
// REVIEW
// ============================================

model Review {
  id        String   @id @default(uuid())
  userId    String
  groundId  String
  rating    Int      // 1-5
  comment   String?
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id])
  ground    Ground   @relation(fields: [groundId], references: [id])
}

// ============================================
// REVENUE REPORT
// ============================================

model RevenueReport {
  id            String   @id @default(uuid())
  groundId      String
  ownerId       String
  month         Int
  year          Int
  totalBookings Int
  totalRevenue  Float
  createdAt     DateTime @default(now())

  ground        Ground   @relation(fields: [groundId], references: [id])
  owner         User     @relation(fields: [ownerId], references: [id])
}

// ============================================
// NOTIFICATION
// ============================================

model Notification {
  id        String   @id @default(uuid())
  userId    String
  title     String
  message   String
  isRead    Boolean  @default(false)
  type      String   // "BOOKING", "PAYMENT", "REVIEW", "SYSTEM"
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id])
}

// ============================================
// EMAIL VERIFICATION
// ============================================

model EmailVerification {
  id        String   @id @default(uuid())
  userId    String
  otp       String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id])
}